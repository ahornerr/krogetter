# Optional: logging level (DEBUG, INFO, WARNING, ERROR)
KROGETTER_LOG_LEVEL=INFO

# Optional: data directory for tracked items and history
KROGETTER_DATA_DIR=

# Optional: default store chain (e.g. KINGSOOPERS, FRED MEYER)
KROGETTER_DEFAULT_CHAIN=KINGSOOPERS

# Optional: default polling interval in seconds
KROGETTER_POLL_INTERVAL=3600

# Optional: use stealth Firefox web fetcher (set false to disable)
KROGETTER_USE_WEB_FETCHER=true
